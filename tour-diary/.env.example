# Required AI providers
APP_EXTERNAL_API_ENABLED=true
APP_GENERATION_DAILY_LIMIT=3
APP_AUTH_TOKEN_SECRET=change-this-dev-secret
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
CLOUDFLARE_IMAGE_TO_IMAGE_MODEL=@cf/runwayml/stable-diffusion-v1-5-img2img
CLOUDFLARE_IMAGE_TO_IMAGE_ENABLED=false

# Required public tourism data providers for judging criteria
# data.go.kr / 한국관광공사_국문 관광정보서비스_GW
KTO_TOUR_API_KEY=
KTO_TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorService2

# data.go.kr / 한국관광공사_반려동물_동반여행_서비스
KTO_PET_TOUR_API_KEY=
KTO_PET_TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorPetTourService2

# Optional public tourism data providers
# data.go.kr / 한국관광공사_두루누비 정보 서비스
KTO_DURUNUBI_API_KEY=

# data.go.kr / 한국관광공사_무장애 여행 정보
KTO_ACCESSIBLE_TOUR_API_KEY=
KTO_ACCESSIBLE_TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorWithService2

# data.go.kr / 한국관광공사_생태 관광 정보_GW
KTO_GREEN_TOUR_API_KEY=
KTO_GREEN_TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/GreenTourService1

# data.go.kr / 기상청 단기예보 또는 현재날씨 API
KMA_WEATHER_API_KEY=
KMA_WEATHER_API_BASE_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0

# Database
# Atlas example:
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/tour-diary
# Local example:
# MONGODB_URI=mongodb://localhost:27017/tour-diary
MONGODB_URI=mongodb://localhost:27017/tour-diary
MONGODB_DATABASE=tour-diary

# Recommended fallback/providers
HUGGINGFACE_TOKEN=
HUGGINGFACE_PROVIDER=fal-ai
HUGGINGFACE_IMAGE_TO_IMAGE_MODEL=black-forest-labs/FLUX.2-dev
KAKAO_REST_API_KEY=

# Optional local image generator fallback
# Stable Diffusion example:
# AI_IMAGE_GENERATE_URL=http://localhost:7860/api/generate
# ComfyUI example:
# AI_IMAGE_GENERATE_URL=http://localhost:8188
AI_IMAGE_GENERATE_URL=
